# Copy this to .env and fill in values

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=eveguru
POSTGRES_USER=eveguru
POSTGRES_PASSWORD=generate_with_openssl_rand_hex_24

# ── Market scanner thresholds ─────────────────────────────────
# Flag shortage when demand > N × current supply
SHORTAGE_RATIO=2.0
# Ignore items with fewer avg daily sales than this
MIN_DAILY_VOLUME=10
# Minimum profit margin % after all fees
MIN_MARGIN_PCT=10.0
# ISK per m³ for Jita → hub courier contracts
SHIPPING_COST_PER_M3=1000
# Adjust to your character's skills/standings
SALES_TAX_PCT=3.6
BROKER_FEE_PCT=3.0

# ── SSL / networking ──────────────────────────────────────────
# IP or hostname of this server (used in the self-signed cert SAN)
SERVER_IP=192.168.135.168

# ── EVE SSO (register at https://developers.eveonline.com) ────
EVE_CLIENT_ID=your_client_id_here
EVE_CLIENT_SECRET=your_client_secret_here
EVE_CALLBACK_URL=https://192.168.135.168/auth/callback

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
