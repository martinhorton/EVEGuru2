# Copy this to .env and fill in values
POSTGRES_DB=eveguru
POSTGRES_USER=eveguru
POSTGRES_PASSWORD=changeme

# Shortage detection: shortages exist when demand/supply ratio exceeds this
SHORTAGE_RATIO=2.0

# Ignore items with fewer than this many average daily sales
MIN_DAILY_VOLUME=10

# Minimum profit margin % after all fees to flag as opportunity
MIN_MARGIN_PCT=10.0

# ISK per m3 for Jita → target hub shipping (courier contracts)
SHIPPING_COST_PER_M3=1000

# EVE market fees (adjust to your character's skills)
SALES_TAX_PCT=3.6
BROKER_FEE_PCT=3.0

# DEBUG or INFO
LOG_LEVEL=INFO
